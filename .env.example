# AOCG AI Офис — фронтенд · шаблон переменных окружения
# Vite читает только переменные с префиксом VITE_ и отдаёт их в браузер.
# ВАЖНО: всё с префиксом VITE_ виден пользователю в собранном бандле.
# Секреты (ключи API, токены) сюда НЕ класть — они живут на бэкенде.
# Скопировать в .env для локальной разработки. Файл .env не коммитить (.gitignore).

# --- Адрес бэкенд-API ---
VITE_API_BASE_URL=https://aocg-ai-office-production.up.railway.app

# --- OAuth client_id (публичные, не секретные — secret хранится на бэкенде) ---
VITE_YANDEX_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=
VITE_MAILRU_CLIENT_ID=
